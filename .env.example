# ==========================================
# GABARITO DE VARIÁVEIS DE AMBIENTE DO PROJETO
# (Copie isso para um arquivo chamado .env.local)
# ==========================================

# 1. Configurações de Inteligência Artificial (Obrigatório)
# ------------------------------------------

# Chave de API do Google Gemini (Recomendado como Principal)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Chave de API do Groq (Recomendado como Fallback/Secundário)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# Qual provedor a aplicação deve tentar usar primeiro? (gemini ou groq)
PRIMARY_AI_PROVIDER=gemini


# 2. Integrações Opcionais (Futuro)
# ------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
